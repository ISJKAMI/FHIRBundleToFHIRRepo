              "section": [
                {
                  "title": "構造情報",
                  "code": {
                    "coding": [
                      {
                        "system": "http://jpfhir.jp/fhir/clins/CodeSystem/document-section",
                        "code": "300",
                        "display": "構造情報セクション"
                      }
